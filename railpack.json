{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "frontend-install": {
      "inputs": [
        { "step": "packages:mise" },
        { "local": true, "include": ["frontend"] }
      ],
      "commands": [
        "cd frontend && npm install --legacy-peer-deps"
      ]
    },
    "frontend-build": {
      "inputs": [
        { "step": "frontend-install" }
      ],
      "commands": [
        "cd frontend && npm run build"
      ]
    },
    "pip-deploy": {
      "inputs": [
        { "step": "packages:mise" },
        { "local": true, "include": ["requirements.txt"] }
      ],
      "commands": [
        "pip install --target /app/python-deps -r requirements.txt"
      ]
    }
  },
  "deploy": {
    "inputs": [
      { "step": "install" },
      { "step": "pip-deploy" },
      { "step": "frontend-build", "include": ["frontend/out"] }
    ]
  }
}
