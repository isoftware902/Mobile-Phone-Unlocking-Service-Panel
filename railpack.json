{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "22"
  },
  "steps": {
    "frontend-install": {
      "inputs": [
        { "step": "packages:mise" },
        { "local": true, "include": ["frontend"] }
      ],
      "commands": [
        "cd frontend && npm install --legacy-peer-deps"
      ]
    },
    "frontend-build": {
      "inputs": [
        { "step": "frontend-install" }
      ],
      "commands": [
        "cd frontend && npm run build"
      ]
    }
  }
}
